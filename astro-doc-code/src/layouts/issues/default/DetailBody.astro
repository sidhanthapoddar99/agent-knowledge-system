---
/**
 * DetailBody — overview page for a single issue.
 *
 * Hosts only the overview and Comprehensive panels. Individual subtasks,
 * notes, and agent-log entries live at their own URLs (see SubDocLayout).
 *
 * Layout shell: [ DetailSidebar ] [ main ] [ MetaSidebar ]
 * panels.ts switches overview ↔ comprehensive; anchors in DetailSidebar
 * navigate to sub-doc pages on click.
 */
import MetaPanel from './parts/shared/MetaPanel.astro';
import DetailSidebar from './parts/detail/DetailSidebar.astro';
import IssueThread from './parts/detail/IssueThread.astro';
import Comprehensive from './parts/detail/Comprehensive.astro';
import MetaSidebar from './parts/detail/MetaSidebar.astro';
import { allStateIcons } from './server/state-icon';
import { extractAndPrefixToc } from './server/toc';
import { TERMINAL, sortSubtasksByState, terminalStartIndex, subtaskPanelKey } from './server/helpers';
import { buildIssueGuide } from './guide';
import type { Issue, IssuesVocabulary } from '@loaders/issues';
import './styles/detail.css';

interface Props {
  issue: Issue;
  vocabulary: IssuesVocabulary;
  baseUrl: string;
}

const { issue, vocabulary, baseUrl } = Astro.props;
const { meta } = issue;

const subtaskDone = issue.subtasks.filter((s) => TERMINAL.includes(s.status)).length;
const subtaskReview = issue.subtasks.filter((s) => s.category === 'review').length;
const notStartedCount = issue.subtasks.filter((s) => s.category === 'not-started').length;
const inProgressCount = issue.subtasks.filter((s) => s.category === 'in-progress').length;
const closedCount = subtaskDone;

const sortedSubtasks = sortSubtasksByState(issue.subtasks);
const terminalStartIdx = terminalStartIndex(sortedSubtasks);

// Guide panel: static template + generated islands (this issue's effective kind set).
const guide = buildIssueGuide(issue.agentLogKinds);

const statusColors = vocabulary.fields?.status?.colors || {};

// Comprehensive panel is the one place multiple subtasks share a DOM —
// prefix heading ids so `#setup` anchors across subtasks don't collide.
const sortedSubtaskDocs = sortedSubtasks.map((s) => {
  const { html, toc } = extractAndPrefixToc(s.html, subtaskPanelKey(s));
  return { ...s, html, toc };
});
---

<div class="issue-layout">
  <DetailSidebar
    baseUrl={baseUrl}
    issue={issue}
    sortedSubtasks={sortedSubtasks}
    terminalStartIdx={terminalStartIdx}
    subtaskDone={subtaskDone}
    subtaskReview={subtaskReview}
    mode="overview"
    activeKey="overview"
  />

  <main class="issue-main">
    <header class="issue-main__header">
      <h1 class="issue-main__title">{meta.title}</h1>
      {meta.description && <p class="issue-main__description">{meta.description}</p>}
      <MetaPanel issue={issue} vocabulary={vocabulary} />
    </header>

    <section class="issue-panel is-active" data-panel="overview" role="tabpanel">
      <div class="issue-body markdown-content"><Fragment set:html={issue.html} /></div>
    </section>

    <section class="issue-panel" data-panel="comments" role="tabpanel" hidden>
      <IssueThread issue={issue} />
    </section>

    <section class="issue-panel" data-panel="guide" role="tabpanel" hidden>
      <div class="issue-doc">
        <div class="issue-doc__body markdown-content" set:html={guide.html} />
      </div>
    </section>

    <section class="issue-panel" data-panel="glossary" role="tabpanel" hidden>
      {issue.glossaryHtml ? (
        <div class="issue-doc">
          <div class="issue-doc__body markdown-content" set:html={issue.glossaryHtml} />
        </div>
      ) : (
        <div class="issue-doc__empty">
          <p class="issue-doc__empty-title">No glossary yet</p>
          <p>
            This issue has no <code>glossary.md</code>. Add one at the issue-folder root to
            record its key terms, semantics, and any conventions it relies on — for example
            what the sidebar <strong>colours</strong> mean in this issue.
          </p>
          <p>
            Suggested shape (use the sections you need — prefer tables and pointers over
            paragraphs): <strong>Colour legend</strong> · <strong>Key terms</strong> ·
            <strong>Conventions</strong>.
          </p>
        </div>
      )}
    </section>

    <Comprehensive
      sortedSubtaskDocs={sortedSubtaskDocs}
      reviewCount={subtaskReview}
      inProgressCount={inProgressCount}
      notStartedCount={notStartedCount}
      closedCount={closedCount}
      statusColors={statusColors}
    />
  </main>

  <MetaSidebar issue={issue} sortedSubtasks={sortedSubtasks} guideHeadings={guide.headings} />
</div>

<script is:inline type="application/json" id="subtask-state-icons" set:html={JSON.stringify(allStateIcons())} />

<script>
  import { initIssuesDetail } from './scripts/detail/client';
  initIssuesDetail();
</script>
