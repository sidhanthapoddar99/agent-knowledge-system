---
/**
 * NotePage — full-page view of one supporting note from notes/.
 * Renders in standalone mode (one doc owns the DOM) or as a hidden panel
 * co-hosted under DetailBody (legacy).
 */
import type { IssueNote } from '@loaders/issues';
import type { TocEntry } from '../../server/toc';
import { notePanelKey } from '../../server/helpers';

interface Props {
  note: IssueNote & { toc?: TocEntry[] };
  standalone?: boolean;
}

const { note: n, standalone = false } = Astro.props;
const pathDisplay = ['notes', ...n.groupPath, `${n.name}.md`].join('/');
---

<section
  class={`issue-panel ${standalone ? 'is-active' : ''}`}
  data-panel={notePanelKey(n)}
  role="tabpanel"
  hidden={!standalone}
>
  <div class="issue-doc">
    <div class="issue-doc__path">{pathDisplay}</div>
    <div class="issue-doc__body markdown-content">
      <Fragment set:html={n.html} />
    </div>
  </div>
</section>
