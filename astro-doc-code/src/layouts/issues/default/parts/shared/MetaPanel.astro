---
/**
 * MetaPanel — inline horizontal strip of issue metadata rendered under the
 * detail-page header. Three explicit lines, always horizontal:
 *   1. ID · Component
 *   2. Status · Priority · Labels
 *   3. Author · Assignees · Created · Updated
 *
 * The vertical / non-compact variant previously shipped here was never
 * used after the header-strip move and has been removed. If a right-rail
 * layout is needed again later, reintroduce it as a sibling component.
 */
import StatusBadge from './StatusBadge.astro';
import { formatRelativeTime } from '../../server/helpers';
import type { Issue, IssuesVocabulary } from '@loaders/issues';

interface Props {
  issue: Issue;
  vocabulary: IssuesVocabulary;
}

const { issue, vocabulary } = Astro.props;
const { meta } = issue;

function formatDate(value: string | null | undefined): string {
  if (!value) return '';
  const d = new Date(value);
  if (isNaN(d.getTime())) return value;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
}

const { rel: updatedRel, full: updatedFull } = formatRelativeTime(issue.updated);
---

<aside class="issue-meta-panel">
  <div class="issue-meta-panel__line">
    <div class="issue-meta-panel__cell"><dt>ID</dt><dd><code class="issue-meta-panel__id">{issue.id}</code></dd></div>
    <div class="issue-meta-panel__cell"><dt>Component</dt><dd>{meta.component.length > 0
      ? meta.component.map((c) => <StatusBadge field="component" value={c} vocabulary={vocabulary.fields} />)
      : <span class="issue-meta-panel__empty">—</span>}</dd></div>
  </div>
  <div class="issue-meta-panel__line">
    <div class="issue-meta-panel__cell"><dt>Status</dt><dd><StatusBadge field="status" value={meta.status} vocabulary={vocabulary.fields} /></dd></div>
    <div class="issue-meta-panel__cell"><dt>Priority</dt><dd><StatusBadge field="priority" value={meta.priority} vocabulary={vocabulary.fields} /></dd></div>
    <div class="issue-meta-panel__cell"><dt>Labels</dt><dd>
      {meta.labels.length > 0
        ? meta.labels.map((l) => <StatusBadge field="labels" value={l} vocabulary={vocabulary.fields} />)
        : <span class="issue-meta-panel__empty">—</span>}
    </dd></div>
  </div>
  <div class="issue-meta-panel__line">
    <div class="issue-meta-panel__cell"><dt>Author</dt><dd>{meta.author || <span class="issue-meta-panel__empty">—</span>}</dd></div>
    <div class="issue-meta-panel__cell"><dt>Assignees</dt><dd>{meta.assignees.length > 0
      ? meta.assignees.join(', ')
      : <span class="issue-meta-panel__empty">—</span>}</dd></div>
    <div class="issue-meta-panel__cell"><dt>Created</dt><dd>{formatDate(issue.created)}</dd></div>
    <div class="issue-meta-panel__cell"><dt>Updated</dt><dd>{updatedRel
      ? <time datetime={issue.updated} title={updatedFull}>{updatedRel}</time>
      : <span class="issue-meta-panel__empty">—</span>}</dd></div>
  </div>
</aside>
