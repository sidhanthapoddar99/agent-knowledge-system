---
/**
 * SubtaskPage — full-page view of one subtask.
 *
 * Two modes:
 *   - panel (default): hidden section inside DetailBody, toggled by panels.ts.
 *     (Used historically. Now unused after the sub-doc URL refactor unless a
 *     layout elects to co-host.)
 *   - standalone: rendered as the sole doc on its own URL (SubDocLayout).
 */
import type { IssueSubtask } from '@loaders/issues';
import type { TocEntry } from '../../server/toc';
import { pad, subtaskPanelKey } from '../../server/helpers';

interface Props {
  subtask: IssueSubtask & { toc?: TocEntry[] };
  statusColors: Record<string, string>;
  standalone?: boolean;
}

const { subtask: s, statusColors, standalone = false } = Astro.props;
const panelKey = subtaskPanelKey(s);
const relPath = ['subtasks', ...s.groupPath, `${s.slug}.md`].join('/');
---

<section
  class={`issue-panel ${standalone ? 'is-active' : ''}`}
  data-panel={panelKey}
  role="tabpanel"
  hidden={!standalone}
>
  <div class="issue-doc">
    <div class="issue-doc__path">{relPath}</div>
    <div class="issue-subtask-page" data-subtask-key={panelKey} data-file={s.filePath} data-state={s.status}>
      <div class="issue-subtask-page__header">
        {s.sequence !== null && <span class="issue-subtask-page__num">{pad(s.sequence)}</span>}
        <span class="issue-subtask-page__title">{s.title}</span>
        <span class="issue-subtask-page__badge" data-state-pill style={statusColors[s.status] ? `--badge-color: ${statusColors[s.status]}` : undefined}>
          {s.status}
        </span>
      </div>
      {s.html && (
        <div class="issue-subtask-page__body markdown-content">
          <Fragment set:html={s.html} />
        </div>
      )}
    </div>
  </div>
</section>
