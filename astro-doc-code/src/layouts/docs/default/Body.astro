---
/**
 * Docs Body - Main content area (Default Style)
 * Does NOT include sidebar or outline - those are separate components
 */

// `title`/`description` are accepted (Layouts pass them) but not rendered here —
// the page h1 comes from the markdown content itself.
interface Props {
  title: string;
  description?: string;
  content: string;
}

const { content } = Astro.props;
---

<main class="docs-content">
  <article class="docs-article">
    <div class="docs-body markdown-content">
      <Fragment set:html={content} />
    </div>

    <slot />
  </article>
</main>
