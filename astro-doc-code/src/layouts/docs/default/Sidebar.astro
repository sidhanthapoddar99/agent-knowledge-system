---
/**
 * Sidebar - Documentation navigation sidebar with recursive nesting
 * Accepts mixed array of items (files) and sections (folders)
 */

import type { SidebarSection, SidebarItem, SidebarNode } from '@/hooks/useSidebar';

interface Props {
  nodes: SidebarNode[];  // Mixed: items (root files) + sections (folders)
  currentPath: string;
}

const { nodes, currentPath } = Astro.props;

// Root segment of the URL (e.g. `user-guide`, `dev-docs`) — namespaces the
// collapse cache per docs section. Stable across renders of the same section.
const sectionRoot = currentPath.split('/').filter(Boolean)[0] || 'docs';

function isActive(href: string): boolean {
  return currentPath === href;
}

function isSectionActive(section: SidebarSection): boolean {
  if (section.href && isActive(section.href)) return true;

  for (const child of section.children) {
    if (child.type === 'item' && isActive(child.href)) return true;
    if (child.type === 'section' && isSectionActive(child)) return true;
  }

  return false;
}

function shouldBeExpanded(section: SidebarSection): boolean {
  // Always expand if contains active item
  if (isSectionActive(section)) return true;
  // Otherwise use collapsed setting
  return !section.collapsed;
}
---

<aside class="sidebar" data-sidebar-root={sectionRoot}>
  <nav class="sidebar__nav" aria-label="Documentation">
    {nodes.map((node, index) => (
      node.type === 'item' ? (
        /* Root-level item (file without folder) */
        <a
          href={node.href}
          class:list={['sidebar__link sidebar__link--top', { 'sidebar__link--active': isActive(node.href) }]}
          aria-current={isActive(node.href) ? 'page' : undefined}
          data-tip={node.title}
        >
          {node.title}
        </a>
      ) : (
        /* Section (folder with children) */
        <div
          class:list={['sidebar__section', { 'sidebar__section--active': isSectionActive(node) }]}
          data-section={index}
          data-collapse-key={node.slug}
          data-collapsed={!shouldBeExpanded(node)}
        >
          {node.children.length > 0 ? (
            <>
              {node.collapsible ? (
                <button
                  class="sidebar__header sidebar__header--collapsible"
                  aria-expanded={shouldBeExpanded(node)}
                  data-collapse-trigger
                >
                  <span data-tip={node.title}>{node.title}</span>
                  <svg class="sidebar__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </button>
              ) : (
                <span class="sidebar__header" data-tip={node.title}>{node.title}</span>
              )}

              <ul class="sidebar__list" data-collapse-content>
                {node.children.map((child) => (
                  child.type === 'item' ? (
                    <li>
                      <a
                        href={child.href}
                        class:list={['sidebar__link', { 'sidebar__link--active': isActive(child.href) }]}
                        aria-current={isActive(child.href) ? 'page' : undefined}
                        data-tip={child.title}
                      >
                        {child.title}
                      </a>
                    </li>
                  ) : (
                    <li class="sidebar__nested">
                      <div
                        class:list={['sidebar__section', 'sidebar__section--nested', { 'sidebar__section--active': isSectionActive(child) }]}
                        data-collapse-key={child.slug}
                        data-collapsed={!shouldBeExpanded(child)}
                      >
                        {child.collapsible ? (
                          <button
                            class="sidebar__header sidebar__header--collapsible sidebar__header--nested"
                            aria-expanded={shouldBeExpanded(child)}
                            data-collapse-trigger
                          >
                            <span data-tip={child.title}>{child.title}</span>
                            <svg class="sidebar__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <polyline points="6 9 12 15 18 9" />
                            </svg>
                          </button>
                        ) : (
                          <span class="sidebar__header sidebar__header--nested" data-tip={child.title}>{child.title}</span>
                        )}
                        <ul class="sidebar__list" data-collapse-content>
                          {child.children.map((subChild) => (
                            subChild.type === 'item' ? (
                              <li>
                                <a
                                  href={subChild.href}
                                  class:list={['sidebar__link', { 'sidebar__link--active': isActive(subChild.href) }]}
                                  aria-current={isActive(subChild.href) ? 'page' : undefined}
                                  data-tip={subChild.title}
                                >
                                  {subChild.title}
                                </a>
                              </li>
                            ) : null
                          ))}
                        </ul>
                      </div>
                    </li>
                  )
                ))}
              </ul>
            </>
          ) : node.href ? (
            <a
              href={node.href}
              class:list={['sidebar__link sidebar__link--top', { 'sidebar__link--active': isActive(node.href) }]}
              aria-current={isActive(node.href) ? 'page' : undefined}
            >
              {node.title}
            </a>
          ) : (
            <span class="sidebar__header" data-tip={node.title}>{node.title}</span>
          )}
        </div>
      )
    ))}
  </nav>
</aside>

<!--
  Sidebar persistence + sync. Runs inline (synchronous, before paint) so the
  restored collapse state shows immediately with no flash of default state.
  - Collapse state cached in localStorage as ONE blob per docs section, keyed
    `sidebar-collapse:<section-root>`, value `{ts, f:{<folder-path>: 0|1}}`.
    Only deviations from the server-rendered default are stored; an empty blob
    is removed. Restore reads exactly one key; the GC scan checks one ts per
    section (and drops legacy v1 per-folder keys). 30-day TTL.
  - Sync wins for ancestors of the active page (force-expanded for visibility);
    the cache owns every other folder. Sync never writes to the cache.
-->
<script is:inline>
  (function () {
    var TTL = 30 * 24 * 60 * 60 * 1000; // 30 days
    var PREFIX = 'sidebar-collapse:';

    // Lazy GC: drop expired blobs and legacy v1 per-folder keys (no `.f`).
    function gc() {
      var now = Date.now();
      try {
        for (var i = localStorage.length - 1; i >= 0; i--) {
          var k = localStorage.key(i);
          if (!k || k.indexOf(PREFIX) !== 0) continue;
          var v = null;
          try { v = JSON.parse(localStorage.getItem(k)); } catch (e) {}
          if (!v || !v.f || typeof v.ts !== 'number' || (now - v.ts) > TTL) localStorage.removeItem(k);
        }
      } catch (e) {}
    }

    function ownTrigger(sec) {
      var btn = sec.querySelector('[data-collapse-trigger]');
      return (btn && btn.closest('[data-collapse-key]') === sec) ? btn : null;
    }

    // Is `el` fully within the visible viewport of scroll-container `container`?
    function fullyVisible(el, container) {
      var er = el.getBoundingClientRect();
      var cr = container.getBoundingClientRect();
      return er.top >= cr.top && er.bottom <= cr.bottom;
    }

    // Center `el` vertically within `container`. scrollTop self-clamps to
    // [0, scrollHeight - clientHeight], so a near-edge / last item lands as
    // close to centre as the remaining room allows (the accepted exception).
    function centerInSidebar(el, container) {
      var er = el.getBoundingClientRect();
      var cr = container.getBoundingClientRect();
      var top = (er.top - cr.top) + container.scrollTop;
      container.scrollTop = top - (container.clientHeight / 2) + (el.offsetHeight / 2);
    }

    function init() {
      var aside = document.querySelector('.sidebar[data-sidebar-root]');
      if (!aside) return;
      gc();
      var key = PREFIX + (aside.getAttribute('data-sidebar-root') || 'docs');
      var state = {};
      try {
        var v = JSON.parse(localStorage.getItem(key));
        if (v && v.f && typeof v.ts === 'number') state = v.f;
      } catch (e) {}

      function save() {
        try {
          if (Object.keys(state).length) localStorage.setItem(key, JSON.stringify({ ts: Date.now(), f: state }));
          else localStorage.removeItem(key);
        } catch (e) {}
      }

      // Server-rendered defaults — only deviations from these get stored.
      var secs = aside.querySelectorAll('[data-collapse-key]');
      var defaults = {};
      secs.forEach(function (sec) {
        defaults[sec.getAttribute('data-collapse-key')] = sec.getAttribute('data-collapsed') === 'true';
      });

      // 1. Restore: apply stored deviations over the defaults.
      secs.forEach(function (sec) {
        var p = sec.getAttribute('data-collapse-key');
        if (!(p in state)) return;
        var collapsed = !!state[p];
        sec.setAttribute('data-collapsed', String(collapsed));
        var btn = ownTrigger(sec);
        if (btn) btn.setAttribute('aria-expanded', String(!collapsed));
      });

      // 2. Sync wins: force-expand ancestors of the active entry, then position it.
      var active = aside.querySelector('.sidebar__link--active');
      if (active) {
        var el = active.parentElement;
        while (el && el !== aside) {
          if (el.matches && el.matches('[data-collapse-key]')) {
            el.setAttribute('data-collapsed', 'false');
            var b = ownTrigger(el);
            if (b) b.setAttribute('aria-expanded', 'true');
          }
          el = el.parentElement;
        }

        // Two positioning cases (no view transitions here — every nav is a full
        // reload, so a fresh document's sidebar always starts at scrollTop 0):
        //   - Cold load / reload / direct open / non-sidebar nav: centre the
        //     active item so it lands mid-sidebar where there's room.
        //   - Click on a sidebar link: keep the sidebar visually still. We stash
        //     the pre-nav scrollTop on click (step 4) and restore it here, only
        //     re-centring if the active item ends up off-screen. This avoids the
        //     jump-on-every-click friction while browsing.
        var fromClick = false, savedScroll = null;
        try {
          fromClick = sessionStorage.getItem('sidebar:fromClick') === '1';
          var s = sessionStorage.getItem('sidebar:scroll');
          if (s !== null) savedScroll = parseInt(s, 10);
          sessionStorage.removeItem('sidebar:fromClick');
          sessionStorage.removeItem('sidebar:scroll');
        } catch (e) {}

        requestAnimationFrame(function () {
          try {
            if (fromClick && savedScroll !== null) {
              aside.scrollTop = savedScroll;
              if (!fullyVisible(active, aside)) centerInSidebar(active, aside);
            } else {
              centerInSidebar(active, aside);
            }
          } catch (e) {}
        });
      }

      // 3. Bind toggles (after restore, so programmatic changes above don't write).
      //    Delete-on-default: toggling back to the server default removes the entry.
      aside.querySelectorAll('[data-collapse-trigger]').forEach(function (trigger) {
        if (trigger.__sbBound) return;
        trigger.__sbBound = true;
        trigger.addEventListener('click', function () {
          var sec = trigger.closest('[data-collapsed]');
          if (!sec) return;
          var next = sec.getAttribute('data-collapsed') !== 'true';
          sec.setAttribute('data-collapsed', String(next));
          trigger.setAttribute('aria-expanded', String(!next));
          var keyEl = trigger.closest('[data-collapse-key]');
          if (keyEl) {
            var p = keyEl.getAttribute('data-collapse-key');
            if (next === defaults[p]) delete state[p];
            else state[p] = next ? 1 : 0;
            save();
          }
        });
      });

      // 4. On sidebar-link navigation, stash the current scroll so the next
      //    (full-reload) page can restore it instead of jumping (see step 2).
      aside.querySelectorAll('.sidebar__link').forEach(function (link) {
        if (link.__sbNavBound) return;
        link.__sbNavBound = true;
        link.addEventListener('click', function () {
          try {
            sessionStorage.setItem('sidebar:scroll', String(aside.scrollTop));
            sessionStorage.setItem('sidebar:fromClick', '1');
          } catch (e) {}
        });
      });
    }

    init();
    document.addEventListener('astro:page-load', init);
  })();
</script>
