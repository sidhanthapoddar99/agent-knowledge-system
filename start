#!/usr/bin/env bash
# Entrypoint for the astro-doc-code framework.
#
# Usage:
#   ./start                preflight (update check → install if needed → build sanity check) → dev server
#   ./start <script>       skip preflight, just run the named script (dev | build | preview | astro …)
#   ./start clean          wipe build caches (.astro, dist, node_modules/.vite) and exit
#   ./start clean <script> wipe caches, then run the script (e.g. './start clean dev')
#
# Preflight steps when invoked with no args:
#   0. Update check — fetch upstream; if behind, prompt Y/n to fast-forward pull.
#   1. Pick a runner — prefer bun, fall back to npm.
#   2. Install dependencies if node_modules is missing OR the lockfile /
#      package.json changed since the last install (stamped hash mismatch).
#   3. Run the production build to catch errors before launching dev.
#   4. Start the dev server.
#
# When to use clean: any time CONFIG_DIR or paths in .env / site.yaml change.
# Astro caches compiled routes by source path; stale entries cause builds to
# import non-existent dist modules or load configs from the previous location.
#
# Skip the update check by exporting START_SKIP_UPDATE_CHECK=1 (e.g. in CI).
set -e

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 0. Update check — if upstream has new commits, offer to fast-forward pull.
#    Bails silently when: not a git repo, no upstream tracked, working tree
#    dirty, branch diverged, no TTY, or START_SKIP_UPDATE_CHECK=1.
update_check() {
  [ "${START_SKIP_UPDATE_CHECK:-0}" = "1" ] && return 0
  [ -t 0 ] || return 0
  command -v git >/dev/null 2>&1 || return 0
  git -C "$DIR" rev-parse --git-dir >/dev/null 2>&1 || return 0

  local upstream
  upstream="$(git -C "$DIR" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null)" || return 0

  if ! git -C "$DIR" diff --quiet || ! git -C "$DIR" diff --cached --quiet; then
    echo "[start] working tree has uncommitted changes — skipping update check"
    return 0
  fi

  echo "[start] checking $upstream for updates..."
  if ! git -C "$DIR" fetch --quiet 2>/dev/null; then
    echo "[start] fetch failed (offline?) — skipping update check"
    return 0
  fi

  local local_sha upstream_sha base_sha ahead
  local_sha="$(git -C "$DIR" rev-parse HEAD)"
  upstream_sha="$(git -C "$DIR" rev-parse '@{u}')"
  [ "$local_sha" = "$upstream_sha" ] && { echo "[start] up to date"; return 0; }

  base_sha="$(git -C "$DIR" merge-base HEAD '@{u}' 2>/dev/null)" || return 0
  if [ "$base_sha" != "$local_sha" ]; then
    echo "[start] local branch has diverged from $upstream — resolve manually before pulling"
    return 0
  fi

  ahead="$(git -C "$DIR" rev-list --count HEAD..@{u} 2>/dev/null || echo '?')"
  echo "[start] $ahead new commit(s) available on $upstream"
  local reply
  read -r -p "[start] pull now? [Y/n] " reply
  case "$reply" in
    ""|y|Y|yes|YES)
      if git -C "$DIR" pull --ff-only --quiet; then
        echo "[start] pulled $ahead commit(s) — continuing"
      else
        echo "[start] pull failed — continuing with current version" >&2
      fi
      ;;
    *)
      echo "[start] skipping pull — continuing with current version"
      ;;
  esac
}

update_check

# 0b. Shallow check — consumer clones don't need git history (the tracker's
#     git-derived dates are a framework-dev concern). If this is a consumer-
#     mode clone (CONFIG_DIR points outside the framework folder) with full
#     history, offer a one-time in-place shrink to a shallow clone.
#     Skipped when: scripted/no-TTY, not a git repo, already shallow, dogfood
#     mode, dirty tree, diverged from upstream, or previously declined.
shallow_check() {
  [ "${START_SKIP_UPDATE_CHECK:-0}" = "1" ] && return 0
  [ -t 0 ] || return 0
  command -v git >/dev/null 2>&1 || return 0
  git -C "$DIR" rev-parse --git-dir >/dev/null 2>&1 || return 0
  [ "$(git -C "$DIR" rev-parse --is-shallow-repository 2>/dev/null)" = "false" ] || return 0
  # resolve the real git dir (works for worktrees/submodules where .git is a file)
  local gitdir
  gitdir="$(git -C "$DIR" rev-parse --absolute-git-dir 2>/dev/null)" || return 0
  [ -f "$gitdir/.start-shallow-declined" ] && return 0

  # Consumer mode iff CONFIG_DIR resolves outside the framework folder.
  local config_dir
  config_dir="$(grep -E '^CONFIG_DIR=' "$DIR/.env" 2>/dev/null | tail -1 | cut -d= -f2- \
    | sed -e 's/[[:space:]]*#.*$//' -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' -e 's/^"\(.*\)"$/\1/' -e "s/^'\(.*\)'\$/\1/")"
  [ -n "$config_dir" ] || return 0
  case "$(cd "$DIR" && cd "$config_dir" 2>/dev/null && pwd)" in
    "$DIR"|"$DIR"/*) return 0 ;;   # resolves at/inside the framework folder → dogfood
    "") return 0 ;;                # unresolvable → don't guess
  esac

  # Same safety rails as the update check.
  git -C "$DIR" diff --quiet 2>/dev/null || return 0
  git -C "$DIR" diff --cached --quiet 2>/dev/null || return 0
  local upstream local_sha upstream_sha
  upstream="$(git -C "$DIR" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null)" || return 0
  local_sha="$(git -C "$DIR" rev-parse HEAD)"
  upstream_sha="$(git -C "$DIR" rev-parse '@{u}' 2>/dev/null)" || return 0
  [ "$local_sha" = "$upstream_sha" ] || return 0

  local size
  size="$(du -sh "$DIR/.git" 2>/dev/null | cut -f1)"
  echo "[start] consumer-mode clone with full git history detected (.git = ${size:-?})"
  echo "[start] a vendored framework doesn't need history — shallow keeps only the current commit"
  local reply
  read -r -p "[start] shrink to a shallow clone now? [y/N] " reply
  case "$reply" in
    y|Y|yes|YES)
      if git -C "$DIR" fetch --depth 1 --quiet 2>/dev/null; then
        git -C "$DIR" reflog expire --expire=now --all 2>/dev/null || true
        git -C "$DIR" gc --prune=now --quiet 2>/dev/null || true
        size="$(du -sh "$DIR/.git" 2>/dev/null | cut -f1)"
        echo "[start] done — .git is now ${size:-?} (future pulls stay shallow)"
      else
        echo "[start] shallow fetch failed — leaving the clone as-is" >&2
      fi
      ;;
    *)
      echo "[start] keeping full history (won't ask again — delete .git/.start-shallow-declined to re-enable)"
      touch "$gitdir/.start-shallow-declined" 2>/dev/null || true
      ;;
  esac
}

shallow_check

cd "$DIR/astro-doc-code"

# Optional `clean` first arg — wipe caches, then either exit or continue
if [ "${1:-}" = "clean" ]; then
  shift
  echo "[start] cleaning caches: .astro/, dist/, node_modules/.vite/"
  rm -rf .astro dist node_modules/.vite
  if [ $# -eq 0 ]; then
    echo "[start] clean done"
    exit 0
  fi
  echo "[start] clean done — continuing with: $*"
fi

# 1. Pick a runner
if command -v bun >/dev/null 2>&1; then
  RUNNER="bun"
  RUN="bun run"
  INSTALL="bun install"
elif command -v npm >/dev/null 2>&1; then
  RUNNER="npm"
  RUN="npm run"
  INSTALL="npm install"
else
  echo "[start] error: neither bun nor npm found on PATH — install one and retry" >&2
  exit 1
fi
echo "[start] runner: $RUNNER"

# 2. Install if node_modules is missing OR the dependency manifests changed
#    since the last install. We stamp a hash of package.json + the runner's
#    lockfile into node_modules after each install; a mismatch (e.g. after
#    pulling a commit that adds a dependency) triggers a re-install. Without
#    this, a stale node_modules silently misses newly-added deps until a build
#    fails to resolve the import.
STAMP="node_modules/.start-deps-stamp"
case "$RUNNER" in
  bun) LOCKFILE="bun.lock" ;;
  npm) LOCKFILE="package-lock.json" ;;
esac

deps_hash() {
  # Hash package.json + the runner's lockfile (whichever exist). Portable
  # across sha256sum (Linux) / shasum (macOS) / cksum (last resort).
  local files=()
  [ -f package.json ] && files+=(package.json)
  [ -f "$LOCKFILE" ] && files+=("$LOCKFILE")
  if command -v sha256sum >/dev/null 2>&1; then
    cat "${files[@]}" | sha256sum | cut -d' ' -f1
  elif command -v shasum >/dev/null 2>&1; then
    cat "${files[@]}" | shasum -a 256 | cut -d' ' -f1
  else
    cat "${files[@]}" | cksum | cut -d' ' -f1
  fi
}

# npm has no cross-project package dedup: every project carries its own full
# node_modules (~420 MB), while bun hardlinks from a global cache so N projects
# cost about one copy. Warn (red) before an npm install; confirm when
# interactive. Background: user-guide → Getting Started → Storage & Disk
# Footprint (05_getting-started/07_storage-and-footprint.md).
npm_disk_warning() {
  printf '\033[1;31m[start] WARNING: installing with npm — no cross-project dedup.\033[0m\n' >&2
  printf '\033[31m[start] npm gives every project its own full node_modules (~420 MB each).\n' >&2
  printf '[start] bun hardlinks packages from a global cache, so N projects cost ~one copy.\n' >&2
  printf '[start] Recommended fix: install bun (https://bun.sh) and re-run ./start.\033[0m\n' >&2
  printf '[start] Details: user-guide → Getting Started → Storage & Disk Footprint.\n' >&2
  if [ -t 0 ] && [ "${START_SKIP_UPDATE_CHECK:-0}" != "1" ]; then
    local reply
    read -r -p "[start] proceed with npm install anyway? [Y/n] " reply
    case "$reply" in
      ""|y|Y|yes|YES) ;;
      *)
        echo "[start] aborted — install bun and re-run ./start" >&2
        exit 1
        ;;
    esac
  fi
}

NEED_INSTALL=""
if [ ! -d node_modules ]; then
  NEED_INSTALL="node_modules missing"
elif [ ! -f "$STAMP" ] || [ "$(cat "$STAMP")" != "$(deps_hash)" ]; then
  NEED_INSTALL="dependency manifest changed since last install"
fi
if [ -n "$NEED_INSTALL" ]; then
  [ "$RUNNER" = "npm" ] && npm_disk_warning
  echo "[start] $NEED_INSTALL — running '$INSTALL'..."
  $INSTALL
  deps_hash > "$STAMP"
fi

# Explicit script — skip preflight, just forward
if [ $# -gt 0 ]; then
  exec $RUN "$@"
fi

# 3. Build sanity check before launching dev
echo "[start] running build to catch errors before dev launch..."
if ! $RUN build; then
  echo "[start] build failed — aborting before dev start" >&2
  exit 1
fi
echo "[start] build clean"

# 4. Start dev
echo "[start] launching dev server..."
exec $RUN dev
