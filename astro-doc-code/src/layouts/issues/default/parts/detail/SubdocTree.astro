---
/**
 * Recursively render a 2-level tree of notes or agent-logs in the sidebar.
 * Files at this level become <a> rows; subgroups become <details> blocks
 * that recursively render the same component for their inner tree.
 *
 * The depth cap (2) is enforced upstream by the loader, so this component
 * doesn't need a guard — it stops naturally when `tree.groups` is empty.
 */
import type { IssueAgentLog, IssueNote } from '@loaders/issues';
import {
  logPanelKey, notePanelKey, brainstormPanelKey, agentMemoryPanelKey,
  noteUrl, logUrl, brainstormUrl, agentMemoryUrl, pad,
  type GroupedTree,
} from '../../server/helpers';
import { parseOrderPrefixLoose, stripOrderPrefixLoose } from '@parsers/core/order-prefix';

type SubdocTree = GroupedTree<IssueNote> | GroupedTree<IssueAgentLog>;

interface Props {
  tree: SubdocTree;
  kind: 'note' | 'log' | 'brainstorm' | 'memory';
  baseUrl: string;
  issueId: string;
  activeKey: string;
  /** Add the `--nested` modifier to the items wrapper (for sub-levels). */
  nested?: boolean;
  /** Folder-path prefix for the collapse-cache key (e.g. `notes`, `notes/design`). */
  pathPrefix?: string;
}

const { tree, kind, baseUrl, issueId, activeKey, nested = false, pathPrefix = (kind === 'note' ? 'notes' : kind === 'brainstorm' ? 'brainstorm' : kind === 'memory' ? 'agent-memory' : 'agent-log') } = Astro.props;

/** Human-readable label: prefix stripped, separators → spaces. Shared by files
 *  and folders, all kinds. */
function cleanLabel(name: string): string {
  return stripOrderPrefixLoose(name).replace(/[-_]/g, ' ').trim() || name;
}

/** Common ordering badge — the padded `NN` prefix, same rule for every kind and
 *  for both files and folders. Empty string when the name has no prefix. */
function prefixNum(name: string): string {
  return pad(parseOrderPrefixLoose(name).position);
}

/** Leading badge for a leaf — mirrors the subtask `__num` treatment. Common rule
 *  is {@link prefixNum}; agent-log layers a precedence override on top (its
 *  `#<iteration>` wins when set). */
function leafNum(item: IssueNote | IssueAgentLog): string {
  if (kind === 'log' && (item as IssueAgentLog).iteration !== null) {
    return `#${(item as IssueAgentLog).iteration}`;
  }
  return prefixNum(item.name);
}

function leafLabel(item: IssueNote | IssueAgentLog): string {
  return cleanLabel(item.name);
}

function leafKey(item: IssueNote | IssueAgentLog): string {
  if (kind === 'log') return logPanelKey(item as IssueAgentLog);
  if (kind === 'brainstorm') return brainstormPanelKey(item as IssueNote);
  if (kind === 'memory') return agentMemoryPanelKey(item as IssueNote);
  return notePanelKey(item as IssueNote);
}

function leafHref(item: IssueNote | IssueAgentLog): string {
  if (kind === 'log') return logUrl(baseUrl, issueId, item as IssueAgentLog);
  if (kind === 'brainstorm') return brainstormUrl(baseUrl, issueId, item as IssueNote);
  if (kind === 'memory') return agentMemoryUrl(baseUrl, issueId, item as IssueNote);
  return noteUrl(baseUrl, issueId, item as IssueNote);
}

/** Total descendants under a tree node — used for the subgroup count. */
function descendantCount(t: SubdocTree): number {
  let n = t.files.length;
  for (const child of t.groups.values()) n += descendantCount(child);
  return n;
}

/** Does any descendant match the active key? Drives auto-expand on load. */
function containsActive(t: SubdocTree): boolean {
  if (t.files.some((f) => leafKey(f) === activeKey)) return true;
  for (const child of t.groups.values()) {
    if (containsActive(child)) return true;
  }
  return false;
}

/** A renderable entry at this tree level — a leaf file or a subgroup folder.
 *  Files and folders are interleaved and sorted lexicographically by raw
 *  on-disk name (including any `NNN_` prefix), so a numbered folder slots in
 *  among numbered files instead of being dumped at the bottom. */
interface SubdocEntry {
  kind: 'leaf' | 'group';
  sortName: string;
  item?: IssueNote | IssueAgentLog;
  groupName?: string;
  child?: SubdocTree;
}

const entries: SubdocEntry[] = [
  ...tree.files.map((item): SubdocEntry => ({ kind: 'leaf', sortName: item.name, item })),
  ...Array.from(tree.groups, ([groupName, child]): SubdocEntry => ({ kind: 'group', sortName: groupName, groupName, child })),
];
entries.sort((a, b) => a.sortName.localeCompare(b.sortName));
---

<div class={`issue-sidebar__items ${nested ? 'issue-sidebar__items--nested' : ''}`}>
  {entries.map((entry) => {
    if (entry.kind === 'leaf') {
      const item = entry.item!;
      const key = leafKey(item);
      const isActive = activeKey === key;
      const label = leafLabel(item);
      const num = leafNum(item);
      const color = (item as { color?: string | null }).color ?? null;
      return (
        <a
          href={leafHref(item)}
          class={`issue-sidebar__item ${isActive ? 'is-active' : ''}`}
          aria-current={isActive ? 'page' : undefined}
          title={label}
        >
          {num && <span class="issue-sidebar__num">{num}</span>}
          <span class="issue-sidebar__label" style={color ? `color: ${color}` : undefined}>{label}</span>
        </a>
      );
    }
    const groupName = entry.groupName!;
    const child = entry.child!;
    const open = containsActive(child);
    const childPath = `${pathPrefix}/${groupName}`;
    const groupNum = prefixNum(groupName);
    const groupLabel = cleanLabel(groupName);
    return (
      <details class="issue-sidebar__subgroup" data-collapse-key={childPath} open={open ? true : undefined}>
        <summary class="issue-sidebar__subgroup-heading" title={groupLabel}>
          <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
          {groupNum && <span class="issue-sidebar__num">{groupNum}</span>}
          <span class="issue-sidebar__subgroup-name">{groupLabel}</span>
          <span class="issue-sidebar__heading-count">{descendantCount(child)}</span>
        </summary>
        <Astro.self
          tree={child}
          kind={kind}
          baseUrl={baseUrl}
          issueId={issueId}
          activeKey={activeKey}
          nested={true}
          pathPrefix={childPath}
        />
      </details>
    );
  })}
</div>
