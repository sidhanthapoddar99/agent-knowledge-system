#!/usr/bin/env bash
# `agent-ks` — model-B dispatcher (collision-safe, prefixed name). Unlike the
# flat docs-* shims it does NOT prepend its basename: it forwards args verbatim
# so cli.mjs resolves `agent-ks <group> <verb>`.
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI="$DIR/../skills/agent-ks-docs/scripts/cli.mjs"
if command -v bun >/dev/null 2>&1; then
  exec bun "$CLI" "$@"
else
  exec node "$CLI" "$@"
fi
