---
/**
 * Recursively render a nested tree of notes or agent-logs in the sidebar.
 * Files at this level become <a> rows; subgroups become <details> blocks
 * that recursively render the same component for their inner tree.
 *
 * The depth cap (MAX_SUBFOLDER_DEPTH) is enforced upstream by the loader, so
 * this component doesn't need a guard — it stops naturally when `tree.groups`
 * is empty.
 */
import type { AgentLogKind, IssueAgentLog, IssueNote } from '@loaders/issues';
import {
  logPanelKey, notePanelKey, brainstormPanelKey, agentMemoryPanelKey,
  noteUrl, logUrl, brainstormUrl, agentMemoryUrl, pad,
  type GroupedTree,
} from '../../server/helpers';
import { agentLogIcon } from '../../server/agent-log-icons';
import { fileTypeIcon } from '../../../../file-type-icons';
import { parseOrderPrefixLoose, stripOrderPrefixLoose } from '@parsers/core/order-prefix';

type SubdocTree = GroupedTree<IssueNote> | GroupedTree<IssueAgentLog>;

interface Props {
  tree: SubdocTree;
  kind: 'note' | 'log' | 'brainstorm' | 'memory';
  baseUrl: string;
  issueId: string;
  activeKey: string;
  /** Add the `--nested` modifier to the items wrapper (for sub-levels). */
  nested?: boolean;
  /** Folder-path prefix for the collapse-cache key (e.g. `notes`, `notes/design`). */
  pathPrefix?: string;
  /** Agent-log kind code → {name, icon} (effective map). Only used for `kind==='log'`. */
  kindMap?: Record<string, AgentLogKind>;
}

const { tree, kind, baseUrl, issueId, activeKey, nested = false, kindMap = {}, pathPrefix = (kind === 'note' ? 'notes' : kind === 'brainstorm' ? 'brainstorm' : kind === 'memory' ? 'agent-memory' : 'agent-log') } = Astro.props;

/** For an agent-log activity folder `NNN_<code>_<name>`: after stripping the order
 *  prefix, if the remainder starts with a known two-letter kind code + `_`, split
 *  it into { kind: <AgentLogKind>, label: <clean name> }. Otherwise no kind. */
function logFolderParts(groupName: string): { kind: AgentLogKind | null; label: string } {
  if (kind === 'log') {
    const rest = stripOrderPrefixLoose(groupName);
    const m = rest.match(/^([a-z]{2})_(.+)$/);
    if (m && kindMap[m[1]]) {
      return { kind: kindMap[m[1]], label: m[2].replace(/[-_]/g, ' ').trim() };
    }
  }
  return { kind: null, label: cleanLabel(groupName) };
}

/** Human-readable label: prefix stripped, separators → spaces. Shared by files
 *  and folders, all kinds. */
function cleanLabel(name: string): string {
  return stripOrderPrefixLoose(name).replace(/[-_]/g, ' ').trim() || name;
}

/** Common ordering badge — the padded `NN` prefix, same rule for every kind and
 *  for both files and folders. Empty string when the name has no prefix. */
function prefixNum(name: string): string {
  return pad(parseOrderPrefixLoose(name).position);
}

/** Numeric *value* of the order prefix, for value-based sorting (so mixed widths
 *  like `20_` and `100_` order by value, not lexically). Unprefixed → +∞ (last). */
function prefixValue(name: string): number {
  const p = parseOrderPrefixLoose(name).position;
  return p === null ? Number.POSITIVE_INFINITY : p;
}

/** Milestone status → sidebar `#<iteration>` badge colour class. Agent-log only. */
function logStatusModifier(item: IssueNote | IssueAgentLog): string {
  if (kind !== 'log') return '';
  const s = ((item as IssueAgentLog).status ?? '').toLowerCase().replace(/\s+/g, '-');
  if (s === 'in-progress' || s === 'wip' || s === 'active') return 'is-in-progress';
  if (s === 'success' || s === 'completed' || s === 'complete' || s === 'done') return 'is-success';
  if (s === 'failed' || s === 'fail' || s === 'error') return 'is-failed';
  if (s === 'not-started' || s === 'todo' || s === 'pending' || s === 'planned') return 'is-not-started';
  return '';
}

/** Leading badge for a leaf — mirrors the subtask `__num` treatment. Common rule
 *  is {@link prefixNum}; agent-log layers a precedence override on top (its
 *  `#<iteration>` wins when set). */
function leafNum(item: IssueNote | IssueAgentLog): string {
  if (kind === 'log') {
    // Milestones show `#<iteration>`; meta files (`0NN`, no iteration) are badge-less.
    const it = (item as IssueAgentLog).iteration;
    return it !== null ? `#${it}` : '';
  }
  return prefixNum(item.name);
}

function leafLabel(item: IssueNote | IssueAgentLog): string {
  return cleanLabel(item.name);
}

function leafKey(item: IssueNote | IssueAgentLog): string {
  if (kind === 'log') return logPanelKey(item as IssueAgentLog);
  if (kind === 'brainstorm') return brainstormPanelKey(item as IssueNote);
  if (kind === 'memory') return agentMemoryPanelKey(item as IssueNote);
  return notePanelKey(item as IssueNote);
}

function leafHref(item: IssueNote | IssueAgentLog): string {
  if (kind === 'log') return logUrl(baseUrl, issueId, item as IssueAgentLog);
  if (kind === 'brainstorm') return brainstormUrl(baseUrl, issueId, item as IssueNote);
  if (kind === 'memory') return agentMemoryUrl(baseUrl, issueId, item as IssueNote);
  return noteUrl(baseUrl, issueId, item as IssueNote);
}

/** Total descendants under a tree node — used for the subgroup count. */
function descendantCount(t: SubdocTree): number {
  let n = t.files.length;
  for (const child of t.groups.values()) n += descendantCount(child);
  return n;
}

/** Does any descendant match the active key? Drives auto-expand on load. */
function containsActive(t: SubdocTree): boolean {
  if (t.files.some((f) => leafKey(f) === activeKey)) return true;
  for (const child of t.groups.values()) {
    if (containsActive(child)) return true;
  }
  return false;
}

/** A renderable entry at this tree level — a leaf file or a subgroup folder.
 *  Files and folders are interleaved and ordered by the precedence chain below
 *  (bucket → iteration → numeric prefix value → lexicographic), so a numbered
 *  folder slots in among numbered files by value instead of by string. */
interface SubdocEntry {
  kind: 'leaf' | 'group';
  sortName: string;
  item?: IssueNote | IssueAgentLog;
  groupName?: string;
  child?: SubdocTree;
}

const entries: SubdocEntry[] = [
  ...tree.files.map((item): SubdocEntry => ({ kind: 'leaf', sortName: item.name, item })),
  ...Array.from(tree.groups, ([groupName, child]): SubdocEntry => ({ kind: 'group', sortName: groupName, groupName, child })),
];

/** Frontmatter `iteration` for an entry, or null. Only leaf agent-log files
 *  carry one — folders and every other kind are always null. This is what
 *  splits agent-log entries into the two sort buckets below. */
function entryIteration(entry: SubdocEntry): number | null {
  if (kind !== 'log' || entry.kind !== 'leaf') return null;
  return (entry.item as IssueAgentLog).iteration;
}

/**
 * Ordering — precedence chain:
 *   0. `memory.md` pin (agent-memory only): the section's index / entry point
 *      always sorts first.
 *   1. Bucket (agent-log only): entries with no `iteration` (goal / summary /
 *      task-list, and folders) come first; `iteration` entries come after.
 *   2. Iteration number (agent-log only): within the iteration bucket, by `#N`.
 *   3. Numeric prefix *value* — so mixed widths (`20_` vs `100_`) order by value,
 *      not lexically. Unprefixed sorts last (+∞).
 *   4. Lexicographic on the raw name — the final tie-break.
 */
entries.sort((a, b) => {
  if (kind === 'memory') {
    const aPin = a.kind === 'leaf' && a.sortName === 'memory' ? 0 : 1;
    const bPin = b.kind === 'leaf' && b.sortName === 'memory' ? 0 : 1;
    if (aPin !== bPin) return aPin - bPin;                                 // 0. index pin
  }
  if (kind === 'log') {
    const ai = entryIteration(a);
    const bi = entryIteration(b);
    if ((ai === null) !== (bi === null)) return ai === null ? -1 : 1;      // 1. bucket
    if (ai !== null && bi !== null && ai !== bi) return ai - bi;           // 2. iteration
  }
  const av = prefixValue(a.sortName), bv = prefixValue(b.sortName);
  if (av !== bv) return av - bv;                                           // 3. prefix value
  return a.sortName.localeCompare(b.sortName);                            // 4. lexicographic
});
---

<div class={`issue-sidebar__items ${nested ? 'issue-sidebar__items--nested' : ''}`}>
  {entries.map((entry) => {
    if (entry.kind === 'leaf') {
      const item = entry.item!;
      const key = leafKey(item);
      const isActive = activeKey === key;
      const label = leafLabel(item);
      const num = leafNum(item);
      const statusMod = logStatusModifier(item);
      const color = (item as { color?: string | null }).color ?? null;
      // Type marker: non-markdown sub-docs (`.html` artifacts, first-class
      // diagrams) get a small glyph so they're distinguishable from a markdown
      // note at a glance. Markdown is the default and stays unmarked. Shared
      // vocabulary with the docs sidebar: `src/layouts/file-type-icons.ts`.
      const typeIcon = fileTypeIcon((item as { docType?: string }).docType);
      return (
        <a
          href={leafHref(item)}
          class={`issue-sidebar__item ${isActive ? 'is-active' : ''}`}
          aria-current={isActive ? 'page' : undefined}
          data-tip={label}
        >
          {num && <span class={`issue-sidebar__num ${statusMod}`}>{num}</span>}
          <span class="issue-sidebar__label" style={color ? `color: ${color}` : undefined}>{label}</span>
          {typeIcon && (
            <span class="issue-sidebar__doctype" data-tip={typeIcon.label} data-tip-always aria-label={typeIcon.label} set:html={typeIcon.svg} />
          )}
        </a>
      );
    }
    const groupName = entry.groupName!;
    const child = entry.child!;
    const open = containsActive(child);
    const childPath = `${pathPrefix}/${groupName}`;
    const { kind: groupKind, label: groupLabel } = logFolderParts(groupName);
    const groupNum = prefixNum(groupName);
    // Row: `NN  <symbol>  <name>  …  <count>` — numeric prefix, then the kind symbol
    // up front (fast custom tooltip = name), the clean name, and the file count on the
    // right. No recognised kind → no symbol, name keeps the code.
    return (
      <details class="issue-sidebar__subgroup" data-collapse-key={childPath} open={open ? true : undefined}>
        <summary class="issue-sidebar__subgroup-heading" data-tip={groupLabel}>
          <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
          {groupNum && <span class="issue-sidebar__num">{groupNum}</span>}
          {groupKind && (
            <span class="issue-sidebar__kind" data-tip={groupKind.name} data-tip-always aria-label={groupKind.name}>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={agentLogIcon(groupKind.icon)} />
            </span>
          )}
          <span class="issue-sidebar__subgroup-name">{groupLabel}</span>
          <span class="issue-sidebar__heading-count">{descendantCount(child)}</span>
        </summary>
        <Astro.self
          tree={child}
          kind={kind}
          baseUrl={baseUrl}
          issueId={issueId}
          activeKey={activeKey}
          nested={true}
          pathPrefix={childPath}
          kindMap={kindMap}
        />
      </details>
    );
  })}
</div>
