---
/**
 * StateTabs — category tabs above the issue list: Active (default) · In Progress ·
 * Review · Not Started · Closed · All. Filtering is by lifecycle CATEGORY, not by
 * the individual status (which shows as the row badge) — a handful of categories
 * keeps the holistic picture; seven status tabs would clutter it.
 *
 * "Active" is the union of the three non-closed categories — it preserves the
 * old default of hiding closed issues on load. The Review tab is drawn in warning
 * colour and also absorbs review-debt (active issues with a subtask awaiting
 * review) so nothing needing a human hides in another tab.
 *
 * Counts are seeded server-side; `client.ts` updates them live as filters narrow.
 */
interface Props {
  activeCount: number;
  inProgressCount: number;
  reviewCount: number;
  notStartedCount: number;
  closedCount: number;
  totalCount: number;
}

const { activeCount, inProgressCount, reviewCount, notStartedCount, closedCount, totalCount } = Astro.props;

const tabs = [
  { key: 'active', label: 'Active', count: activeCount },
  { key: 'in-progress', label: 'In Progress', count: inProgressCount },
  { key: 'review', label: 'Review', count: reviewCount, highlight: true },
  { key: 'not-started', label: 'Not Started', count: notStartedCount },
  { key: 'closed', label: 'Closed', count: closedCount },
  { key: 'all', label: 'All', count: totalCount },
];
---

<div class="issues-state-tabs" id="issues-state-tabs" role="tablist">
  {tabs.map((tab) => (
    <button
      type="button"
      class={`issues-state-tabs__btn ${tab.highlight ? 'is-review' : ''}`}
      data-state-tab={tab.key}
      role="tab"
      aria-selected={tab.key === 'active' ? 'true' : 'false'}
    >
      <span class="issues-state-tabs__label">{tab.label}</span>
      <span class="issues-state-tabs__count" data-state-count={tab.key}>{tab.count}</span>
    </button>
  ))}
</div>

<style>
  .issues-state-tabs[hidden] { display: none; }
  .issues-state-tabs {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--color-border-default);
    margin: 1rem 0 0.75rem;
    flex-wrap: wrap;
  }
  .issues-state-tabs__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.85rem;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    color: var(--color-text-muted);
    font-size: var(--ui-text-body);
    font-family: inherit;
    cursor: pointer;
    transition: color 0.1s ease, border-color 0.1s ease;
  }
  .issues-state-tabs__btn:hover { color: var(--color-text-primary); }
  .issues-state-tabs__btn[aria-selected='true'] {
    color: var(--color-text-primary);
    border-bottom-color: var(--color-brand-primary);
  }
  .issues-state-tabs__btn.is-review[aria-selected='true'] {
    border-bottom-color: var(--color-warning);
  }
  .issues-state-tabs__btn.is-review .issues-state-tabs__count {
    color: var(--color-warning);
    background: color-mix(in srgb, var(--color-warning) 18%, transparent);
  }
  .issues-state-tabs__count {
    font-size: var(--ui-text-micro);
    color: var(--color-text-muted);
    font-family: var(--font-family-mono);
    padding: 0.05rem 0.4rem;
    border-radius: 10px;
    background: color-mix(in srgb, var(--color-border-default) 60%, transparent);
  }
  .issues-state-tabs__btn[aria-selected='true'] .issues-state-tabs__count {
    color: var(--color-text-primary);
  }
</style>
