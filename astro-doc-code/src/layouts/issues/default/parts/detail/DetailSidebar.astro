---
/**
 * DetailSidebar — left-rail nav shared between the overview page and each
 * standalone sub-doc page.
 *
 * Sub-doc entries (subtasks / notes / agent-log) are always anchors that
 * navigate to the sub-doc's own URL. Overview / Comprehensive are buttons
 * on the overview page (panel swap via panels.ts) and anchors back to the
 * overview on sub-doc pages.
 *
 * `activeKey` marks the currently-rendered item. Subtask state icons still
 * cycle on click — handled by scripts/detail/client.ts.
 */
import type { Issue, IssueSubtask } from '@loaders/issues';
import { groupByPath, groupSubtasks, detailUrl } from '../../server/helpers';
import SubdocTree from './SubdocTree.astro';
import SubtaskTree from './SubtaskTree.astro';

interface Props {
  baseUrl: string;
  issue: Issue;
  /** Kept for API compatibility — sidebar groups subtasks by folder now. */
  sortedSubtasks?: IssueSubtask[];
  terminalStartIdx?: number;
  subtaskDone: number;
  subtaskReview: number;
  /** 'overview' when rendered inside DetailBody; 'subdoc' for SubDocLayout. */
  mode?: 'overview' | 'subdoc';
  /** Panel key of the currently-active item (e.g. 'overview', 'subtask-foo'). */
  activeKey?: string;
}

const {
  baseUrl, issue, subtaskDone, subtaskReview,
  mode = 'overview', activeKey = 'overview',
} = Astro.props;
const subtaskTotal = issue.subtasks.length;
const overviewHref = detailUrl(baseUrl, issue.id);
const comprehensiveHref = `${overviewHref}#comprehensive`;
const isOverviewMode = mode === 'overview';

const noteTree = groupByPath(issue.notes);
const logTree = groupByPath(issue.agentLogs);
const subtaskTree = groupSubtasks(issue.subtasks, issue.subtaskGroups);

const activeNotesGroupOpen = activeKey.startsWith('note-');
const activeLogGroupOpen = activeKey.startsWith('log-');

// Tracker slug (e.g. `todo`) — namespaces the collapse cache alongside the issue id.
const tracker = baseUrl.replace(/^\/+/, '').replace(/\/+$/, '');
---

<aside class="issue-sidebar" data-tracker={tracker} data-issue-id={issue.id}>
  <a href={baseUrl} class="issue-sidebar__back">
    <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="10 4 6 8 10 12"/></svg>
    <span>All issues</span>
  </a>

  <nav class="issue-sidebar__nav">
    <details class="issue-sidebar__section" data-collapse-key="this-issue" open>
      <summary class="issue-sidebar__heading">
        <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
        <span>This issue</span>
      </summary>
      <div class="issue-sidebar__items">
        {isOverviewMode ? (
          <button
            type="button"
            class={`issue-sidebar__item ${activeKey === 'overview' ? 'is-active' : ''}`}
            data-panel="overview"
            aria-current={activeKey === 'overview' ? 'page' : undefined}
          >
            <span class="issue-sidebar__label">Overview</span>
          </button>
        ) : (
          <a href={overviewHref} class="issue-sidebar__item" data-panel="overview">
            <span class="issue-sidebar__label">Overview</span>
          </a>
        )}
        {subtaskTotal > 0 && (
          isOverviewMode ? (
            <button
              type="button"
              class={`issue-sidebar__item ${activeKey === 'comprehensive' ? 'is-active' : ''}`}
              data-panel="comprehensive"
              aria-current={activeKey === 'comprehensive' ? 'page' : undefined}
            >
              <span class="issue-sidebar__label">Comprehensive</span>
              <span class="issue-sidebar__count">{subtaskTotal}</span>
            </button>
          ) : (
            <a href={comprehensiveHref} class="issue-sidebar__item" data-panel="comprehensive">
              <span class="issue-sidebar__label">Comprehensive</span>
              <span class="issue-sidebar__count">{subtaskTotal}</span>
            </a>
          )
        )}
      </div>
    </details>

    <details class="issue-sidebar__section" data-collapse-key="notes" open={activeNotesGroupOpen ? true : undefined}>
      <summary class="issue-sidebar__heading">
        <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
        <span>Notes</span>
        {issue.notes.length > 0 && <span class="issue-sidebar__heading-count">{issue.notes.length}</span>}
      </summary>
      {issue.notes.length === 0 ? (
        <div class="issue-sidebar__items"><div class="issue-sidebar__empty">No notes</div></div>
      ) : (
        <SubdocTree tree={noteTree} kind="note" baseUrl={baseUrl} issueId={issue.id} activeKey={activeKey} />
      )}
    </details>

    <details class="issue-sidebar__section" data-collapse-key="subtasks" open>
      <summary class="issue-sidebar__heading">
        <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
        <span>Subtasks</span>
        {subtaskTotal > 0 && (
          <span class="issue-sidebar__heading-count" id="sidebar-subtasks-count">
            {subtaskDone}/{subtaskTotal}
            {subtaskReview > 0 && <span class="issue-sidebar__review-dot" title={`${subtaskReview} awaiting review`} aria-hidden="true"></span>}
          </span>
        )}
      </summary>
      {subtaskTotal === 0 ? (
        <div class="issue-sidebar__items"><div class="issue-sidebar__empty">No subtasks</div></div>
      ) : (
        <SubtaskTree node={subtaskTree} baseUrl={baseUrl} issueId={issue.id} activeKey={activeKey} />
      )}
    </details>

    <details class="issue-sidebar__section" data-collapse-key="agent-log" open={activeLogGroupOpen ? true : undefined}>
      <summary class="issue-sidebar__heading">
        <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
        <span>Agent log</span>
        {issue.agentLogs.length > 0 && <span class="issue-sidebar__heading-count">{issue.agentLogs.length}</span>}
      </summary>
      {issue.agentLogs.length === 0 ? (
        <div class="issue-sidebar__items"><div class="issue-sidebar__empty">No agent-log entries</div></div>
      ) : (
        <SubdocTree tree={logTree} kind="log" baseUrl={baseUrl} issueId={issue.id} activeKey={activeKey} />
      )}
    </details>

    {issue.comments.length > 0 && (
      <details class="issue-sidebar__section" data-collapse-key="comments" open>
        <summary class="issue-sidebar__heading">
          <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
          <span>Comments</span>
          <span class="issue-sidebar__heading-count">{issue.comments.length}</span>
        </summary>
        <div class="issue-sidebar__items">
          {isOverviewMode ? (
            <button type="button" class="issue-sidebar__item" data-panel="comments" data-scroll="comment-issue">
              <span class="issue-sidebar__label">Issue</span>
            </button>
          ) : (
            <a href={`${overviewHref}#comments`} class="issue-sidebar__item" data-panel="comments">
              <span class="issue-sidebar__label">Issue</span>
            </a>
          )}
          {issue.comments.map((c) => (
            isOverviewMode ? (
              <button type="button" class="issue-sidebar__item" data-panel="comments" data-scroll={`comment-${c.sequence}`}>
                <span class="issue-sidebar__label">#{String(c.sequence).padStart(3, '0')} · {c.author || 'unknown'}</span>
              </button>
            ) : (
              <a href={`${overviewHref}#comment-${c.sequence}`} class="issue-sidebar__item" data-panel="comments">
                <span class="issue-sidebar__label">#{String(c.sequence).padStart(3, '0')} · {c.author || 'unknown'}</span>
              </a>
            )
          ))}
        </div>
      </details>
    )}
  </nav>

  <!--
    Sidebar persistence + sync (inline → runs before paint, no flash of default state).
    - Collapse state cached in localStorage as ONE blob per issue, keyed
      `issues-sidebar-collapse:<tracker>:<issue-id>`, value `{ts, f:{<folder-path>: 0|1}}`.
      Only deviations from the server-rendered default are stored; an empty blob
      is removed. Restore reads exactly one key; the GC scan checks one ts per
      issue (and drops legacy v1 per-folder keys). 30-day TTL.
    - Sync wins for ancestors of the active sub-doc (force-opened for visibility);
      the cache owns every other folder. Sync never writes to the cache.
  -->
  <script is:inline>
    (function () {
      var TTL = 30 * 24 * 60 * 60 * 1000; // 30 days
      var PREFIX = 'issues-sidebar-collapse:';

      // Is `el` fully within the visible viewport of scroll-container `container`?
      function fullyVisible(el, container) {
        var er = el.getBoundingClientRect();
        var cr = container.getBoundingClientRect();
        return er.top >= cr.top && er.bottom <= cr.bottom;
      }

      // Center `el` vertically within `container`. scrollTop self-clamps to
      // [0, scrollHeight - clientHeight], so a near-edge / last item lands as
      // close to centre as the remaining room allows (the accepted exception).
      function centerInSidebar(el, container) {
        var er = el.getBoundingClientRect();
        var cr = container.getBoundingClientRect();
        var top = (er.top - cr.top) + container.scrollTop;
        container.scrollTop = top - (container.clientHeight / 2) + (el.offsetHeight / 2);
      }

      // Lazy GC: drop expired blobs and legacy v1 per-folder keys (no `.f`).
      function gc() {
        var now = Date.now();
        try {
          for (var i = localStorage.length - 1; i >= 0; i--) {
            var k = localStorage.key(i);
            if (!k || k.indexOf(PREFIX) !== 0) continue;
            var v = null;
            try { v = JSON.parse(localStorage.getItem(k)); } catch (e) {}
            if (!v || !v.f || typeof v.ts !== 'number' || (now - v.ts) > TTL) localStorage.removeItem(k);
          }
        } catch (e) {}
      }

      function init() {
        var aside = document.querySelector('.issue-sidebar[data-issue-id]');
        if (!aside) return;
        gc();
        var key = PREFIX + (aside.getAttribute('data-tracker') || '') + ':' +
                  (aside.getAttribute('data-issue-id') || '');
        var state = {};
        try {
          var v = JSON.parse(localStorage.getItem(key));
          if (v && v.f && typeof v.ts === 'number') state = v.f;
        } catch (e) {}

        function save() {
          try {
            if (Object.keys(state).length) localStorage.setItem(key, JSON.stringify({ ts: Date.now(), f: state }));
            else localStorage.removeItem(key);
          } catch (e) {}
        }

        // Server-rendered defaults — only deviations from these get stored.
        var details = aside.querySelectorAll('details[data-collapse-key]');
        var defaults = {};
        details.forEach(function (d) {
          defaults[d.getAttribute('data-collapse-key')] = d.open;
        });

        // 1. Restore stored deviations (cache stores `collapsed`; open = !collapsed).
        details.forEach(function (d) {
          var p = d.getAttribute('data-collapse-key');
          if (p in state) d.open = !state[p];
        });

        // 2. Sync wins: open every <details> ancestor of the active entry, then position it.
        var active = aside.querySelector('.issue-sidebar__item.is-active');
        if (active) {
          var el = active.parentElement;
          while (el && el !== aside) {
            if (el.tagName === 'DETAILS') el.open = true;
            el = el.parentElement;
          }

          // Two positioning cases (sub-doc nav is a full reload, so a fresh
          // document's sidebar always starts at scrollTop 0):
          //   - Cold load / reload / direct open: centre the active item.
          //   - Click on a sub-doc link: keep the sidebar visually still by
          //     restoring the pre-nav scrollTop stashed on click (step 4), only
          //     re-centring if the active item ends up off-screen. Avoids the
          //     jump-on-every-click friction while browsing.
          // (Overview/Comprehensive are panel-swap buttons — no reload, not stashed.)
          var fromClick = false, savedScroll = null;
          try {
            fromClick = sessionStorage.getItem('issues-sidebar:fromClick') === '1';
            var s = sessionStorage.getItem('issues-sidebar:scroll');
            if (s !== null) savedScroll = parseInt(s, 10);
            sessionStorage.removeItem('issues-sidebar:fromClick');
            sessionStorage.removeItem('issues-sidebar:scroll');
          } catch (e) {}

          requestAnimationFrame(function () {
            try {
              if (fromClick && savedScroll !== null) {
                aside.scrollTop = savedScroll;
                if (!fullyVisible(active, aside)) centerInSidebar(active, aside);
              } else {
                centerInSidebar(active, aside);
              }
            } catch (e) {}
          });
        }

        // 3. Persist user toggles. `toggle` events fire as queued tasks, so the
        //    programmatic changes in steps 1–2 would still reach listeners bound
        //    here — the suppress flag (cleared on a later task) swallows them.
        //    Delete-on-default: toggling back to the server default removes the entry.
        var suppress = true;
        setTimeout(function () { suppress = false; }, 0);
        details.forEach(function (d) {
          if (d.__sbBound) return;
          d.__sbBound = true;
          d.addEventListener('toggle', function () {
            if (suppress) return;
            var p = d.getAttribute('data-collapse-key');
            if (d.open === defaults[p]) delete state[p];
            else state[p] = d.open ? 0 : 1;
            save();
          });
        });

        // 4. On sub-doc navigation (anchors only — panel-swap buttons don't
        //    reload), stash the current scroll so the next page can restore it
        //    instead of jumping (see step 2).
        aside.querySelectorAll('a.issue-sidebar__item').forEach(function (link) {
          if (link.__sbNavBound) return;
          link.__sbNavBound = true;
          link.addEventListener('click', function () {
            try {
              sessionStorage.setItem('issues-sidebar:scroll', String(aside.scrollTop));
              sessionStorage.setItem('issues-sidebar:fromClick', '1');
            } catch (e) {}
          });
        });
      }

      init();
      document.addEventListener('astro:page-load', init);
    })();
  </script>
</aside>
