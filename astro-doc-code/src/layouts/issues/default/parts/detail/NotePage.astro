---
/**
 * NotePage — full-page view of one supporting note from notes/.
 * Renders in standalone mode (one doc owns the DOM) or as a hidden panel
 * co-hosted under DetailBody (legacy).
 */
import path from 'path';
import type { IssueNote } from '@loaders/issues';
import type { TocEntry } from '../../server/toc';
import { notePanelKey, brainstormPanelKey, agentMemoryPanelKey } from '../../server/helpers';

interface Props {
  note: IssueNote & { toc?: TocEntry[] };
  standalone?: boolean;
  /** Folder this doc lives under — 'notes' (default), 'brainstorm', or
   *  'agent-memory'. Drives the path label and panel-key namespace when NotePage
   *  is reused for those note-shaped collections. */
  prefix?: 'notes' | 'brainstorm' | 'agent-memory';
}

const { note: n, standalone = false, prefix = 'notes' } = Astro.props;
// Use the real on-disk filename so the path label carries the true extension
// (`.md`, `.html` for an artifact, `.mmd`/… for a diagram) rather than assuming
// markdown.
const pathDisplay = [prefix, ...n.groupPath, path.basename(n.filePath)].join('/');
const panelKey = prefix === 'brainstorm' ? brainstormPanelKey(n)
  : prefix === 'agent-memory' ? agentMemoryPanelKey(n)
  : notePanelKey(n);
---

<section
  class={`issue-panel ${standalone ? 'is-active' : ''}`}
  data-panel={panelKey}
  role="tabpanel"
  hidden={!standalone}
>
  <div class="issue-doc">
    <div class="issue-doc__path">{pathDisplay}</div>
    <div class="issue-doc__body markdown-content">
      <Fragment set:html={n.html} />
    </div>
  </div>
</section>
