#!/usr/bin/env bash
# `docs` — model-B dispatcher. Unlike the flat docs-* shims it does NOT prepend
# its basename: it forwards args verbatim so cli.mjs resolves `docs <group> <verb>`.
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI="$DIR/../skills/documentation-guide/scripts/cli.mjs"
if command -v bun >/dev/null 2>&1; then
  exec bun "$CLI" "$@"
else
  exec node "$CLI" "$@"
fi
