---
import StatusBadge from './StatusBadge.astro';
import { formatRelativeTime, effectiveStatus } from '../../server/helpers';
import type { Issue, IssuesVocabulary } from '@loaders/issues';

interface Props {
  issue: Issue;
  href: string;
  vocabulary: IssuesVocabulary;
}

const { issue, href, vocabulary } = Astro.props;
const { meta } = issue;
const { rel: updatedRel, full: updatedFull } = formatRelativeTime(issue.updated);
---

<article class="issue-card">
  <a href={href} class="issue-card__link">
    <div class="issue-card__main">
      <h3 class="issue-card__title">{meta.title}</h3>
      {meta.description && <p class="issue-card__description">{meta.description}</p>}
      <div class="issue-card__badges">
        <StatusBadge field="status" value={effectiveStatus(issue)} vocabulary={vocabulary.fields} />
        <StatusBadge field="priority" value={meta.priority} vocabulary={vocabulary.fields} />
        {meta.component.map((c) => <StatusBadge field="component" value={c} vocabulary={vocabulary.fields} />)}
        {meta.labels.map((l) => <StatusBadge field="labels" value={l} vocabulary={vocabulary.fields} />)}
      </div>
    </div>
    <div class="issue-card__meta">
      <span class="issue-card__id">{issue.id}</span>
      {updatedRel && <span class="issue-card__updated">updated <time datetime={issue.updated} title={updatedFull}>{updatedRel}</time></span>}
    </div>
  </a>
</article>
